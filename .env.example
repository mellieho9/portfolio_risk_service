# Plaid
PLAID_ACCESS_TOKEN=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | development | production

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=

# Database
DB_PASSWORD=
DB_URL=postgresql://postgres:${DB_PASSWORD}@localhost:5432/riskdb

# AWS (S3 model storage + EC2 Spot training)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_MODEL_URI=s3://your-bucket/models/latest/
S3_DATA_URI=s3://your-bucket/training-data/
